# MCP Read-Only Argo CD Server - secrets.env example
# Copy this file to ~/.config/lukleh/mcp-read-only-argocd/secrets.env

# Session tokens from browser cookies
# Get these from your browser after logging into Argo CD:
# 1. Open browser developer tools (F12)
# 2. Go to Application tab -> Cookies
# 3. Copy the value of the 'argocd.token' cookie

# Staging connection
ARGOCD_SESSION_STAGING=your-session-token-here

# Production connection
ARGOCD_SESSION_PRODUCTION=your-session-token-here

# Local connection
ARGOCD_SESSION_LOCAL=your-session-token-here

# Optional: Override timeouts (in seconds)
# ARGOCD_TIMEOUT_STAGING=60
# ARGOCD_TIMEOUT_PRODUCTION=30
